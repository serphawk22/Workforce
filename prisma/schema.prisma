generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  avatarUrl    String?
  role         String   @default("EMPLOYEE") // EMPLOYEE, ADMIN
  displayName  String?
  firstLoginRequired Boolean @default(false)
  isActive     Boolean  @default(true)
  themePreference String @default("light")
  notificationPreferences String @default("{}")
  createdAt    DateTime @default(now())

  // Employment details
  employeeId     String?
  department     String?
  manager        String?
  joiningDate    DateTime?
  employmentType String?
  workLocation   String?
  office         String?
  leaveBalance   Int?
  salary         Int?
  lastSalaryDate DateTime?
  paymentStatus  String?

  // Bank details
  accountHolderName String?
  bankName          String?
  accountNumber     String?
  ifscCode          String?
  branch            String?
  upiId             String?
  panNumber         String?
  taxId             String?

  ownedWorkspaces  Workspace[]
  memberships      WorkspaceMember[]
  assignedTasks    Task[]          @relation("TaskAssignee")
  reportedTasks    Task[]          @relation("TaskReporter")
  comments              Comment[]
  invitesSent           PendingInvite[]                @relation("InviteSender")
  reassignmentsInitiated  ReassignmentHistory[]          @relation("ReassignmentBy")
  reassignedFrom          ReassignmentHistory[]          @relation("PreviousAssignee")
  reassignedTo            ReassignmentHistory[]          @relation("NewAssignee")
  activityLogEntries      ActivityLog[]
  attachments             Attachment[]
  notifications           Notification[]
  subtasks                Subtask[]
  workUpdates             WorkUpdate[]
  dailyWorkEntries        DailyWorkEntry[]
  chatChannels            ChatChannel[]          @relation("ChannelCreator")
  chatMessages            ChatMessage[]          @relation("MessageAuthor")
  channelMemberships      ChatChannelMember[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())

  owner    User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members  WorkspaceMember[]
  projects Project[]
  invites  PendingInvite[]

  @@unique([ownerId, name])
}

model WorkspaceMember {
  id          String @id @default(cuid())
  userId      String
  workspaceId String
  role        String @default("MEMBER") // OWNER, ADMIN, MEMBER

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model PendingInvite {
  id          String   @id @default(cuid())
  email       String
  workspaceId String
  invitedById String
  token       String   @unique @default(cuid())
  status      String   @default("PENDING") // PENDING, ACCEPTED, EXPIRED, CANCELLED
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)
}

model Project {
  id          String   @id @default(cuid())
  name        String
  key         String   @default("")
  description String?
  workspaceId String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  boards    Board[]
  labels    Label[]
  sprints   Sprint[]
  dailyWorkEntries DailyWorkEntry[]
}

model Board {
  id        String   @id @default(cuid())
  projectId String
  name      String   @default("Main Board")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns Column[]

  @@unique([projectId])
}

model Column {
  id      String @id @default(cuid())
  boardId String
  name    String
  order   Int

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]
}

model Sprint {
  id        String   @id @default(cuid())
  projectId String
  name      String
  goal      String?
  startDate DateTime?
  endDate   DateTime?
  status    String   @default("PLANNED") // PLANNED, ACTIVE, COMPLETED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]
}

model Task {
  id          String    @id @default(cuid())
  columnId    String
  title       String
  description String?
  type        String    @default("TASK") // EPIC, TASK, STORY, BUG, FEATURE_REQUEST, IMPROVEMENT, SUBTASK
  epicId      String?
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  assigneeId  String?
  reporterId  String
  dueDate     DateTime?
  sprintId    String?
  issueKey    String?
  code        String?   @unique
  category    String?
  githubLink      String?
  productionUrl   String?
  dateOfDevAcceptOrStart  DateTime?
  dateOfDevComplete       DateTime?
  dateOfQaOrUatStart      DateTime?
  dateOfQaOrUatComplete   DateTime?
  dateOfReleaseToProd     DateTime?
  order           Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  column    Column      @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assignee  User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter  User        @relation("TaskReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  sprint    Sprint?     @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  epic      Task?       @relation("TaskEpic", fields: [epicId], references: [id], onDelete: SetNull)
  epics     Task[]      @relation("TaskEpic")
  labels        TaskLabel[]
  comments      Comment[]
  reassignments ReassignmentHistory[]
  activityLog   ActivityLog[]
  attachments   Attachment[]
  notifications Notification[]
  subtasks      Subtask[]
  workUpdates   WorkUpdate[]
  dailyWorkEntries DailyWorkEntry[]
}

model ChatChannel {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  category    String   @default("General")
  isPrivate   Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())

  createdBy User               @relation("ChannelCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members   ChatChannelMember[]
  messages  ChatMessage[]
}

model ChatChannelMember {
  id        String @id @default(cuid())
  channelId String
  userId    String

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model ChatMessage {
  id        String    @id @default(cuid())
  channelId String
  authorId  String
  content   String
  replyTo   String?
  isPinned  Boolean   @default(false)
  reactions String    @default("[]")
  createdAt DateTime  @default(now())
  editedAt  DateTime?

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author  User        @relation("MessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
}

model Label {
  id        String @id @default(cuid())
  name      String
  color     String
  projectId String

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskLabels TaskLabel[]

  @@unique([name, projectId])
}

model TaskLabel {
  id      String @id @default(cuid())
  taskId  String
  labelId String

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model ReassignmentHistory {
  id                 String   @id @default(cuid())
  taskId             String
  previousAssigneeId String?
  newAssigneeId      String?
  changedById        String
  reason             String?
  createdAt          DateTime @default(now())

  task             Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  previousAssignee User? @relation("PreviousAssignee", fields: [previousAssigneeId], references: [id], onDelete: SetNull)
  newAssignee      User? @relation("NewAssignee", fields: [newAssigneeId], references: [id], onDelete: SetNull)
  changedBy        User  @relation("ReassignmentBy", fields: [changedById], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  action    String   // created, assigned, reassigned, status_changed, priority_changed, comment_added, attachment_added
  fieldName String?
  oldValue  String?
  newValue  String?
  metadata  String?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Attachment {
  id           String   @id @default(cuid())
  taskId       String
  fileName     String
  fileSize     Int
  fileType     String
  url          String
  uploadedById String
  createdAt    DateTime @default(now())

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // assignment, reassignment, completion, mention, comment
  title     String
  message   String
  taskId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subtask {
  id        String   @id @default(cuid())
  taskId    String
  title     String
  code      String?  @unique
  status    String   @default("TODO") // TODO, IN_PROGRESS, REVIEW, TESTING, DONE
  createdById String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)
  workUpdates WorkUpdate[]
}

model WorkUpdate {
  id           String   @id @default(cuid())
  taskId       String
  userId       String
  subtaskId    String?
  status       String   // TODO, IN_PROGRESS, REVIEW, TESTING, DONE
  progressNotes String?
  workSummary  String?
  githubLink   String?
  productionUrl String?
  timeSpent    Int      @default(0) // minutes
  createdAt    DateTime @default(now())
  updatedAt    DateTime? @updatedAt

  task    Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtask Subtask? @relation(fields: [subtaskId], references: [id], onDelete: SetNull)
}

model DailyWorkEntry {
  id                   String   @id @default(cuid())
  employeeId           String
  projectId            String?
  taskId               String?
  todayWork            String
  todayWorkCompleted   String   // YES, PARTIALLY, NO
  yesterdayPlan        String?  // JSON: yesterday's planned tasks
  yesterdayCompleted   String?  // JSON: which yesterday tasks were completed
  tomorrowTask         String
  status               String   // COMPLETED, IN_PROGRESS, BLOCKED, NEED_REVIEW
  blockers             String?
  referenceLinks       String?  // JSON array of {type, url}
  attachments          String?  // JSON array of {name, url, type}
  submittedAt          DateTime @default(now())
  updatedAt            DateTime @updatedAt

  employee User    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task     Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
}
